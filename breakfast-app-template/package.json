{
  "name": "breakfast-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "cd apps/backend && bun run dev",
    "dev:frontend": "cd apps/frontend && bun run dev",
    "build": "bun run build:frontend && bun run build:backend",
    "build:frontend": "cd apps/frontend && bun run build",
    "build:backend": "cd apps/backend && bun run build",
    "db:generate": "cd apps/backend && drizzle-kit generate",
    "db:migrate": "cd apps/backend && drizzle-kit migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0"
  }
}
