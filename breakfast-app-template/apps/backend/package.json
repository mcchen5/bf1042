    "@elysiajs/swagger": "^1.0.0",
    "@breakfast/api": "workspace:*",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.3.0"
  }
