{
  "name": "auto-dev",
  "version": "0.1.0",
  "description": "AI-Native Software Development Agent",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "auto-dev": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run --watch src/index.ts",
    "watch": "bun run --watch src/index.ts",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev:backend": "cd apps/backend && bun run dev",
    "dev:frontend": "cd apps/frontend && bun run dev",
    "build:backend": "cd apps/backend && bun run build",
    "build:frontend": "cd apps/frontend && bun run build",
    "typecheck:backend": "cd apps/backend && bun run typecheck",
    "typecheck:frontend": "cd apps/frontend && bun run typecheck",
    "typecheck:api": "cd packages/api && bun run typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "commander": "^12.0.0",
    "inquirer": "^10.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "glob": "^10.3.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
